---
import Layout from '../components/Layout.astro';
import { selectedPublications } from '../data/publications';
---

<Layout title="Frédéric Bouchard | Ultrafast Quantum Photonics">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <div class="kicker">Ultrafast quantum photonics</div>
        <h1>Frédéric Bouchard</h1>
        <p class="lede">
          I am a researcher at the National Research Council Canada working on ultrafast photonic approaches to quantum information processing, quantum communication, and nonlinear quantum optics.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/research">Explore research</a>
          <a class="button" href="/publications">View publications</a>
          <a class="button" href="/contact">Contact</a>
        </div>
      </div>

      <div class="orb-card" aria-label="Abstract ultrafast pulse illustration">
        <div class="card-label">telecom · temporal modes · nonlinear optics</div>
        <div class="card-big">Quantum information at the speed of light.</div>
        <div class="pulse-line"></div>
        <div class="pulse p1"></div>
        <div class="pulse p2"></div>
        <div class="pulse p3"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Research themes</h2>
      <p class="section-intro">
        My work combines ultrafast optics, quantum information, and nonlinear photonics to build high-speed quantum technologies compatible with telecom wavelengths.
      </p>

      <div class="grid three">
        <article class="card">
          <h3>Ultrafast temporal modes</h3>
          <p>Encoding, manipulating, and measuring quantum information in picosecond-scale time bins and optical temporal modes.</p>
          <div class="tag-row">
            <span class="tag">time-bin encoding</span>
            <span class="tag">interferometry</span>
          </div>
        </article>

        <article class="card">
          <h3>Nonlinear quantum optics</h3>
          <p>Using χ² and χ³ nonlinearities for frequency conversion, squeezing, photon-number-state manipulation, and quantum measurement.</p>
          <div class="tag-row">
            <span class="tag">Kerr effect</span>
            <span class="tag">OPA</span>
          </div>
        </article>

        <article class="card">
          <h3>Photonic quantum processing</h3>
          <p>Developing scalable architectures for high-rate photonic quantum circuits, measurement, and feed-forward in temporal modes.</p>
          <div class="tag-row">
            <span class="tag">quantum circuits</span>
            <span class="tag">telecom</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Selected publications</h2>
      <div class="pub-list">
        {selectedPublications.map((pub) => (
          <article class="pub">
            <div class="pub-title">{pub.title}</div>
            <div class="pub-meta">{pub.venue} · {pub.year}</div>
            <p>{pub.description}</p>
          </article>
        ))}
      </div>
      <div class="hero-actions">
        <a class="button" href="/publications">See more publications</a>
      </div>
    </div>
  </section>
</Layout>
