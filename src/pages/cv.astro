---
import Layout from '../components/Layout.astro';
---

<Layout title="CV | Frédéric Bouchard">
  <section class="page-title">
    <div class="container">
      <div class="kicker">CV</div>
      <h1>Curriculum vitae</h1>
      <p class="lede">
        A downloadable CV can be added here as <code>public/cv.pdf</code>.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/cv.pdf">Download CV</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content">
      <h2>Profile</h2>
      <p>
        Researcher in ultrafast quantum photonics, quantum information, and nonlinear optics at the National Research Council Canada.
      </p>
    </div>
  </section>
</Layout>
