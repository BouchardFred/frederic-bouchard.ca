---
import Layout from '../components/Layout.astro';
import { selectedPublications } from '../data/publications';
---

<Layout title="Publications | Frédéric Bouchard">
  <section class="page-title">
    <div class="container">
      <div class="kicker">Publications</div>
      <h1>Publications</h1>
      <p class="lede">
        Selected papers, preprints, and conference contributions. This page is currently a starter list and can be expanded with DOI, arXiv, journal, and PDF links.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container pub-list">
      {selectedPublications.map((pub) => (
        <article class="pub">
          <div class="pub-title">{pub.title}</div>
          <div class="pub-meta">{pub.venue} · {pub.year}</div>
          <p>{pub.description}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
