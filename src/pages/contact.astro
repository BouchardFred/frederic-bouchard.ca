---
import Layout from '../components/Layout.astro';
---

<Layout title="Contact | Frédéric Bouchard">
  <section class="page-title">
    <div class="container">
      <div class="kicker">Contact</div>
      <h1>Contact</h1>
      <p class="lede">
        For research collaborations, student inquiries, speaking invitations, or media requests, please get in touch.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <article class="card">
        <h3>Email</h3>
        <p>Add your preferred professional email address here.</p>
      </article>

      <article class="card">
        <h3>Affiliation</h3>
        <p>National Research Council Canada<br />Quantum and Nanotechnologies</p>
      </article>

      <article class="card">
        <h3>Profiles</h3>
        <p>Add links to Google Scholar, ORCID, GitHub, LinkedIn, and institutional profile pages.</p>
      </article>

      <article class="card">
        <h3>Location</h3>
        <p>Canada</p>
      </article>
    </div>
  </section>
</Layout>
