---
import Layout from '../components/Layout.astro';
---

<Layout title="Talks | Frédéric Bouchard">
  <section class="page-title">
    <div class="container">
      <div class="kicker">Talks</div>
      <h1>Talks & news</h1>
      <p class="lede">
        Conference presentations, invited talks, posters, and updates.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container pub-list">
      <article class="pub">
        <div class="pub-title">Programmable quantum circuits with ultrafast time-bin encoding</div>
        <div class="pub-meta">Quantum 2.0 Conference · Glasgow · 2026</div>
        <p>Poster presentation on ultrafast temporal encoding and programmable photonic quantum circuits.</p>
      </article>
    </div>
  </section>
</Layout>
